.mypy_cache/
.coverage
htmlcov/
.tox/

# Virtual environments
venv/
env/
.venv/
ENV/

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docker
Dockerfile*
.dockerignore
docker-compose*.yml

# Logs
*.log

# Environment
.env*
