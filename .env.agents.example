# HyperCode Agent Crew Configuration
# Copy this to .env.agents and fill in your values

# ======================
# API KEYS
# ======================
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxx

# ======================
# DATABASE
# ======================
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=
POSTGRES_USER=

# ======================
# REDIS
# ======================
REDIS_URL=redis://redis

# ======================
# AGENT MODELS (Optional Override)
# ======================
# STRATEGIST_MODEL=claude-3-opus-20240229
# ARCHITECT_MODEL=claude-3-opus-20240229
# SPECIALIST_MODEL=claude-3-5-sonnet-20241022

# ======================
# ORCHESTRATOR
# ======================
ORCHESTRATOR_PORT=8080
ORCHESTRATOR_DEBUG=false

# ======================
# TRAE INTEGRATION
# ======================
TRAE_WORKSPACE_PATH=/path/to/your/workspace
TRAE_MCP_ENABLED=true

# ======================
# LOGGING
# ======================
LOG_LEVEL=INFO
LOG_FORMAT=json
